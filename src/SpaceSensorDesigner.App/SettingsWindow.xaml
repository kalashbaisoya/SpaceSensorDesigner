<Window x:Class="SpaceSensorDesigner.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SpaceSensorDesigner.App.Converters"
        Title="Settings" Height="668" Width="560"
        Icon="pack://application:,,,/Assets/appicon.ico"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize"
        Background="{StaticResource WindowBrush}"
        FontFamily="Segoe UI" FontSize="13">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="44" ResizeBorderThickness="0"
                      CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:InverseBooleanConverter x:Key="InverseBool" />

        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,14" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
        <Style x:Key="Row" TargetType="Grid">
            <Setter Property="Margin" Value="0,7,0,0" />
        </Style>
        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="RowHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,1,0,0" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Background="{StaticResource PanelBrush}">
                <TextBlock Text="Settings" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextBrush}"
                           VerticalAlignment="Center" Margin="18,0" />
                <Button Style="{StaticResource CloseButton}" Content="&#xE8BB;" HorizontalAlignment="Right"
                        WindowChrome.IsHitTestVisibleInChrome="True" Click="OnCloseClick" />
                <Border Height="1" VerticalAlignment="Bottom" Background="{StaticResource BorderBrush2}" />
            </Grid>

            <!-- Body -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,16,18,4">
                <StackPanel>
                    <!-- General -->
                    <TextBlock Text="GENERAL" Style="{StaticResource SectionHeader}" Margin="2,0,0,6" />
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <CheckBox Content="Open new designs in 3D (isometric) view" IsChecked="{Binding DefaultViewIsometric}" />
                            <CheckBox Content="Show the grid on start" IsChecked="{Binding ShowGridOnStart}" Margin="0,8,0,0" />
                            <CheckBox Content="Show the coverage heatmap on start" IsChecked="{Binding ShowHeatmapOnStart}" Margin="0,8,0,0" />
                            <CheckBox Content="Reopen the last project when the app starts" IsChecked="{Binding ReopenLastProject}" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Editing -->
                    <TextBlock Text="EDITING" Style="{StaticResource SectionHeader}" Margin="2,0,0,6" />
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <Grid Style="{StaticResource Row}" Margin="0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Grid snap size" Style="{StaticResource RowLabel}" />
                                <Slider Grid.Column="1" VerticalAlignment="Center" Minimum="0.05" Maximum="1.0"
                                        TickFrequency="0.05" IsSnapToTickEnabled="True" Value="{Binding SnapSizeMeters}" />
                                <TextBlock Grid.Column="2" Style="{StaticResource RowLabel}" HorizontalAlignment="Right"
                                           Text="{Binding SnapSizeMeters, StringFormat={}{0:0.00}m}" />
                            </Grid>

                            <Grid Style="{StaticResource Row}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Default sensor mount height" Style="{StaticResource RowLabel}" />
                                <Slider Grid.Column="1" VerticalAlignment="Center" Minimum="1.5" Maximum="5.0"
                                        TickFrequency="0.1" IsSnapToTickEnabled="True" Value="{Binding DefaultSensorHeightMeters}" />
                                <TextBlock Grid.Column="2" Style="{StaticResource RowLabel}" HorizontalAlignment="Right"
                                           Text="{Binding DefaultSensorHeightMeters, StringFormat={}{0:0.0}m}" />
                            </Grid>

                            <Grid Style="{StaticResource Row}">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/><ColumnDefinition Width="56"/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Auto-save" Style="{StaticResource RowLabel}" />
                                    <TextBlock Text="Saves the current file on a timer (needs a saved file)." Style="{StaticResource RowHint}" />
                                </StackPanel>
                                <Slider Grid.Column="1" VerticalAlignment="Center" Minimum="0" Maximum="30"
                                        TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding AutosaveMinutes}" />
                                <TextBlock Grid.Column="2" Style="{StaticResource RowLabel}" HorizontalAlignment="Right"
                                           Text="{Binding AutosaveMinutes, StringFormat={}{0}m}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Updates -->
                    <TextBlock Text="UPDATES" Style="{StaticResource SectionHeader}" Margin="2,0,0,6" />
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="Update feed URL (optional)" Style="{StaticResource RowLabel}" />
                            <TextBlock Text="A JSON manifest — { &quot;version&quot;: &quot;1.2.0&quot;, &quot;url&quot;: &quot;…&quot; }. Leave blank to disable update checks."
                                       Style="{StaticResource RowHint}" Margin="0,1,0,5" />
                            <TextBox Text="{Binding UpdateFeedUrl, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="Check for updates on startup" IsChecked="{Binding CheckForUpdatesOnStartup}" Margin="0,10,0,0" />
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="Check now" Style="{StaticResource ToolbarButton}"
                                        Background="{StaticResource SidebarBrush}"
                                        Command="{Binding CheckForUpdateCommand}"
                                        IsEnabled="{Binding IsCheckingUpdate, Converter={StaticResource InverseBool}}" />
                                <TextBlock Text="{Binding UpdateStatus}" Style="{StaticResource RowLabel}"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="12,0,0,0"
                                           TextTrimming="CharacterEllipsis" MaxWidth="330" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- About -->
                    <TextBlock Text="ABOUT" Style="{StaticResource SectionHeader}" Margin="2,0,0,6" />
                    <Border Style="{StaticResource SettingsCard}">
                        <StackPanel>
                            <TextBlock Text="{Binding VersionText}" Style="{StaticResource RowLabel}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding DataFolder}" Style="{StaticResource RowHint}" Margin="0,3,0,0" />
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="Open data folder" Style="{StaticResource ToolbarButton}"
                                        Background="{StaticResource SidebarBrush}" Command="{Binding OpenDataFolderCommand}" />
                                <Button Content="Reset to defaults" Style="{StaticResource ToolbarButton}"
                                        Background="{StaticResource SidebarBrush}" Command="{Binding ResetDefaultsCommand}" Margin="8,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,10">
                    <Button Content="Cancel" Style="{StaticResource ToolbarButton}" Background="{StaticResource SidebarBrush}"
                            Command="{Binding CancelCommand}" Width="90" />
                    <Button Content="Save" Style="{StaticResource AccentButton}" Command="{Binding SaveCommand}"
                            Width="110" Margin="8,0,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
