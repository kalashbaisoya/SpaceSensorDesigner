<Window x:Class="SpaceSensorDesigner.App.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SpaceSensorDesigner.App.Converters"
        Title="SpaceSensor Designer" Height="660" Width="1000"
        MinHeight="560" MinWidth="880"
        Icon="pack://application:,,,/Assets/appicon.ico"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource WindowBrush}"
        FontFamily="Segoe UI" FontSize="13">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="46" ResizeBorderThickness="6"
                      CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />

        <!-- Hero gradient for the left brand panel -->
        <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="0.6,1">
            <GradientStop Color="#F98A82" Offset="0" />
            <GradientStop Color="#F2726F" Offset="0.55" />
            <GradientStop Color="#E9635F" Offset="1" />
        </LinearGradientBrush>

        <!-- Big primary action tile -->
        <Style x:Key="HeroAction" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Height" Value="70" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="14" Background="{TemplateBinding Background}" Padding="18,0">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E85F5C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary / outline action tile -->
        <Style x:Key="OutlineAction" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Height" Value="70" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="14" Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" Padding="18,0">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SidebarBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Template chip -->
        <Style x:Key="Chip" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="17" Background="{StaticResource SidebarBrush}"
                                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" Padding="16,0">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- A recent-project row (whole card is a button) -->
        <Style x:Key="RecentCard" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="12" Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" Padding="12,10">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SidebarBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="4,2">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ============ LEFT: brand hero ============ -->
            <Border Grid.Column="0" Background="{StaticResource HeroBrush}">
                <Grid Margin="40,34">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Logo + name -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Border Width="44" Height="44" CornerRadius="13" Background="#33FFFFFF">
                            <TextBlock Text="⌂" Foreground="White" FontSize="24" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock Text="SpaceSensor" Foreground="White" FontSize="19" FontWeight="Bold" />
                            <TextBlock Text="Designer" Foreground="#EDFFFFFF" FontSize="15" Margin="0,-2,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Tagline -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <TextBlock Foreground="White" FontSize="26" FontWeight="Bold" TextWrapping="Wrap"
                                   LineHeight="32" Text="Design spaces. Place thermal sensors. See coverage instantly." />
                        <TextBlock Foreground="#E8FFFFFF" FontSize="13.5" TextWrapping="Wrap" Margin="0,14,0,0"
                                   LineHeight="20"
                                   Text="Draw a floor plan, drop MLX90640 sensors, and let the optimizer find the fewest sensors for full coverage — all offline." />
                    </StackPanel>

                    <!-- Footer -->
                    <StackPanel Grid.Row="2">
                        <Rectangle Height="1" Fill="#33FFFFFF" Margin="0,0,0,14" />
                        <TextBlock Text="{Binding Version}" Foreground="#DFFFFFFF" FontSize="12" />
                        <TextBlock Text="Runs 100% locally · no cloud, no account" Foreground="#BFFFFFFF" FontSize="11" Margin="0,3,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============ RIGHT: actions + recent ============ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="46" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Caption bar (drag + window buttons) -->
                <Grid Grid.Row="0" Background="Transparent">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="MinButton" Style="{StaticResource CaptionButton}" Content="&#xE921;" Click="OnMinimize" />
                        <Button x:Name="CloseButton" Style="{StaticResource CloseButton}" Content="&#xE8BB;" Click="OnClose" />
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="44,6,44,32">
                    <StackPanel>
                        <!-- Start -->
                        <TextBlock Text="Start a project" Style="{StaticResource TitleText}" FontSize="18" Margin="0,4,0,14" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Style="{StaticResource HeroAction}"
                                    Command="{Binding NewProjectCommand}" ToolTip="Start from a sample apartment">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="＋" FontSize="26" VerticalAlignment="Center" Margin="0,0,12,0" />
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="New Project" FontSize="15" FontWeight="SemiBold" />
                                        <TextBlock Text="Sample apartment to start from" FontSize="11.5" Foreground="#E8FFFFFF" />
                                    </StackPanel>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2" Style="{StaticResource OutlineAction}"
                                    Command="{Binding OpenProjectCommand}" ToolTip="Open an existing .spacedesign file">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📂" FontSize="22" VerticalAlignment="Center" Margin="0,0,12,0" />
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Open Project…" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Text="Browse for a .spacedesign file" FontSize="11.5" Foreground="{StaticResource TextMutedBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <TextBlock Text="Or start from a template" Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" Margin="2,18,0,8" />
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource Chip}" Content="Blank" Command="{Binding NewBlankCommand}" />
                            <Button Style="{StaticResource Chip}" Content="Studio" Command="{Binding NewFromTemplateCommand}" CommandParameter="studio" />
                            <Button Style="{StaticResource Chip}" Content="1-Bedroom" Command="{Binding NewFromTemplateCommand}" CommandParameter="onebed" />
                            <Button Style="{StaticResource Chip}" Content="2-Bedroom" Command="{Binding NewFromTemplateCommand}" CommandParameter="twobed" />
                        </StackPanel>

                        <!-- Recent -->
                        <Grid Margin="0,28,0,10">
                            <TextBlock Text="Recent projects" Style="{StaticResource TitleText}" FontSize="18" VerticalAlignment="Center" />
                            <Button Style="{StaticResource LinkButton}" Content="Clear all" HorizontalAlignment="Right"
                                    Command="{Binding ClearRecentCommand}"
                                    Visibility="{Binding HasRecent, Converter={StaticResource BoolToVis}}" />
                        </Grid>

                        <!-- Empty state -->
                        <Border CornerRadius="12" Background="{StaticResource SidebarBrush}" Padding="20,24"
                                Visibility="{Binding HasRecent, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="🗂" FontSize="28" HorizontalAlignment="Center" Opacity="0.6" />
                                <TextBlock Text="No recent projects yet" Foreground="{StaticResource TextBrush}"
                                           FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,8,0,2" />
                                <TextBlock Text="Projects you create or open will appear here." Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- List -->
                        <ItemsControl ItemsSource="{Binding Recent}"
                                      Visibility="{Binding HasRecent, Converter={StaticResource BoolToVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource RecentCard}"
                                            Command="{Binding DataContext.OpenRecentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{Binding Path}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="38" Height="38" CornerRadius="10"
                                                    Background="{StaticResource AccentSoftBrush}" Margin="0,0,12,0">
                                                <TextBlock Text="{Binding Initials}" Foreground="{StaticResource AccentBrush}"
                                                           FontWeight="Bold" FontSize="14"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13.5"
                                                           Foreground="{StaticResource TextBrush}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock FontSize="11.5" Foreground="{StaticResource TextMutedBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding LastOpened}" />
                                            </StackPanel>

                                            <Button Grid.Column="2" Style="{StaticResource LinkButton}" Content="✕"
                                                    VerticalAlignment="Center" FontSize="12"
                                                    Command="{Binding DataContext.RemoveRecentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Remove from list" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- Settings / quit, pinned bottom-left of the right pane -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                            Margin="44,0,0,10">
                    <Button Style="{StaticResource LinkButton}" Command="{Binding OpenSettingsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="14" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Text="Settings" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <TextBlock Text="·" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="8,0" />
                    <Button Style="{StaticResource LinkButton}" Content="Quit" Command="{Binding ExitCommand}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
