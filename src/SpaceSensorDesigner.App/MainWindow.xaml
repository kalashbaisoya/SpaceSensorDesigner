<Window x:Class="SpaceSensorDesigner.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:SpaceSensorDesigner.App.Controls"
        xmlns:conv="clr-namespace:SpaceSensorDesigner.App.Converters"
        Title="SpaceSensor Designer" Height="860" Width="1380"
        MinHeight="640" MinWidth="1080"
        Icon="pack://application:,,,/Assets/appicon.ico"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource WindowBrush}"
        FontFamily="Segoe UI" FontSize="13">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="56" ResizeBorderThickness="6"
                      CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:EnumMatchConverter x:Key="EnumMatch" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:NullToVisibilityConverter x:Key="NullToVis" />
        <conv:InverseBooleanConverter x:Key="InverseBool" />
        <conv:CountToVisibilityConverter x:Key="CountToVis" />
    </Window.Resources>

    <Border BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ================= TOP BAR (custom caption) ================= -->
            <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left group lives in a flexible column and CLIPS from the right, so the
                         coverage badge, Optimize and the window caption buttons on the right are
                         never pushed off-screen. -->
                    <Border Grid.Column="0" ClipToBounds="True">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0"
                                    WindowChrome.IsHitTestVisibleInChrome="True">
                            <Border Width="30" Height="30" CornerRadius="9" Background="{StaticResource AccentGradientBrush}" Margin="0,0,10,0">
                                <TextBlock Text="⌂" Foreground="White" FontSize="16" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center" Margin="0,0,14,0">
                                <TextBlock Text="SpaceSensor Designer" FontSize="14.5" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                <StackPanel Orientation="Horizontal" Margin="0,1,0,0">
                                    <ComboBox ItemsSource="{Binding FloorNames}" SelectedIndex="{Binding ActiveFloorIndex}"
                                              Height="22" MinWidth="118" FontSize="11" VerticalContentAlignment="Center"
                                              ToolTip="Switch floor / apartment" />
                                    <Button Content="＋" Style="{StaticResource ToolbarButton}" Height="22" Padding="7,0" FontSize="12"
                                            Command="{Binding AddFloorCommand}" ToolTip="Add a floor" />
                                    <Button Content="🗑" Style="{StaticResource ToolbarButton}" Height="22" Padding="6,0" FontSize="11"
                                            Command="{Binding RemoveFloorCommand}" ToolTip="Remove this floor" />
                                </StackPanel>
                            </StackPanel>

                            <Button Content="&#x2302;  Home" Style="{StaticResource ToolbarButton}" Command="{Binding GoHomeCommand}"
                                    ToolTip="Back to the start screen" />
                            <Button Content="New" Style="{StaticResource ToolbarButton}" Command="{Binding NewCommand}" />
                            <Button Content="Open" Style="{StaticResource ToolbarButton}" Command="{Binding OpenCommand}" />
                            <Button Content="Save" Style="{StaticResource ToolbarButton}" Command="{Binding SaveCommand}" />
                            <Button Content="Import ▾" Style="{StaticResource ToolbarButton}" Click="OnDropdownButtonClick"
                                    ToolTip="Import a floor plan (image / PDF / CAD DXF)">
                                <Button.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="Floor plan image (PNG/JPG)…" Command="{Binding ImportBackgroundCommand}" />
                                        <MenuItem Header="PDF floor plan…" Command="{Binding ImportPdfCommand}" />
                                        <MenuItem Header="CAD drawing (DXF)…" Command="{Binding ImportDxfCommand}" />
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                            <Button Content="Export ▾" Style="{StaticResource ToolbarButton}" Click="OnDropdownButtonClick"
                                    ToolTip="Export a coverage report, sensor schedule or floor image">
                                <Button.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem Header="Coverage report (HTML)…" Command="{Binding ExportReportCommand}" />
                                        <MenuItem Header="Sensor schedule (CSV)…" Command="{Binding ExportCsvCommand}" />
                                        <MenuItem Header="Floor image (PNG)…" Command="{Binding ExportPngCommand}" />
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>

                            <Rectangle Width="1" Height="22" Fill="{StaticResource BorderBrush2}" Margin="10,0" />

                            <CheckBox Content="Heatmap" IsChecked="{Binding ShowHeatmap}" VerticalAlignment="Center" Margin="4,0" Foreground="{StaticResource TextBrush}" />
                            <CheckBox Content="Overlap" IsChecked="{Binding ShowRedundancy}" VerticalAlignment="Center" Margin="4,0" Foreground="{StaticResource TextBrush}"
                                      ToolTip="Colour the floor by how many sensors overlap each area" />
                            <CheckBox Content="Pyramids" IsChecked="{Binding ShowCones}" VerticalAlignment="Center" Margin="4,0" Foreground="{StaticResource TextBrush}" />
                            <CheckBox Content="Grid" IsChecked="{Binding ShowGrid}" VerticalAlignment="Center" Margin="4,0" Foreground="{StaticResource TextBrush}" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <Border Background="{StaticResource SidebarBrush}" CornerRadius="9" Padding="12,5" Margin="0,0,10,0" VerticalAlignment="Center">
                            <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"
                                       Text="{Binding CoveredPercent, StringFormat=Coverage {0:0.#}%}" />
                        </Border>
                        <Button Style="{StaticResource AccentButton}" Command="{Binding OptimizeCommand}" Margin="0,0,8,0"
                                IsEnabled="{Binding IsOptimizing, Converter={StaticResource InverseBool}}"
                                Content="✨  Optimize" ToolTip="Auto-place the fewest MLX90640 sensors for maximum coverage" />

                        <Button x:Name="MinButton" Style="{StaticResource CaptionButton}" Content="&#xE921;" Click="OnMinimize" />
                        <Button x:Name="MaxButton" Style="{StaticResource CaptionButton}" Content="&#xE922;" Click="OnMaximizeRestore" />
                        <Button x:Name="CloseButton" Style="{StaticResource CloseButton}" Content="&#xE8BB;" Click="OnClose" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ================= CANVAS + FLOATING OVERLAYS ================= -->
            <Grid Grid.Row="1">
                <!-- Full-bleed design surface -->
                <ctrl:DesignSurface x:Name="Surface" ViewModel="{Binding}" />

                <!-- Floating left tool rail -->
                <Border Style="{StaticResource FloatingCard}" HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="16,16,0,0" Padding="6,8">
                    <StackPanel>
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolButton}" ToolTip="Select / move (V)"
                                     IsChecked="{Binding ActiveTool, Converter={StaticResource EnumMatch}, ConverterParameter=Select}">
                            <StackPanel><Path Style="{StaticResource ToolIcon}" Data="{StaticResource IconSelect}"/><TextBlock Text="Select" FontSize="8.5" HorizontalAlignment="Center" Margin="0,2,0,0"/></StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolButton}" ToolTip="Draw walls — click to chain, Esc to finish"
                                     IsChecked="{Binding ActiveTool, Converter={StaticResource EnumMatch}, ConverterParameter=Wall}">
                            <StackPanel><Path Style="{StaticResource ToolIcon}" Data="{StaticResource IconWall}"/><TextBlock Text="Wall" FontSize="8.5" HorizontalAlignment="Center" Margin="0,2,0,0"/></StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolButton}" ToolTip="Door (Phase 1 stub)"
                                     IsChecked="{Binding ActiveTool, Converter={StaticResource EnumMatch}, ConverterParameter=Door}">
                            <StackPanel><Path Style="{StaticResource ToolIcon}" Data="{StaticResource IconDoor}"/><TextBlock Text="Door" FontSize="8.5" HorizontalAlignment="Center" Margin="0,2,0,0"/></StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolButton}" ToolTip="Window (Phase 1 stub)"
                                     IsChecked="{Binding ActiveTool, Converter={StaticResource EnumMatch}, ConverterParameter=Window}">
                            <StackPanel><Path Style="{StaticResource ToolIcon}" Data="{StaticResource IconWindow}"/><TextBlock Text="Window" FontSize="8.5" HorizontalAlignment="Center" Margin="0,2,0,0"/></StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolButton}" ToolTip="Furniture — click to drop, or drag from the library"
                                     IsChecked="{Binding ActiveTool, Converter={StaticResource EnumMatch}, ConverterParameter=Furniture}">
                            <StackPanel><Path Style="{StaticResource ToolIcon}" Data="{StaticResource IconFurniture}"/><TextBlock Text="Furniture" FontSize="8.5" HorizontalAlignment="Center" Margin="0,2,0,0"/></StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolButton}" ToolTip="Thermal sensors — click to drop, or drag from the library"
                                     IsChecked="{Binding ActiveTool, Converter={StaticResource EnumMatch}, ConverterParameter=Sensor}">
                            <StackPanel><Path Style="{StaticResource ToolIcon}" Data="{StaticResource IconSensor}"/><TextBlock Text="Sensor" FontSize="8.5" HorizontalAlignment="Center" Margin="0,2,0,0"/></StackPanel>
                        </RadioButton>
                        <RadioButton GroupName="Tools" Style="{StaticResource ToolButton}" ToolTip="Draw a room rectangle"
                                     IsChecked="{Binding ActiveTool, Converter={StaticResource EnumMatch}, ConverterParameter=Room}">
                            <StackPanel><Path Style="{StaticResource ToolIcon}" Data="{StaticResource IconRoom}"/><TextBlock Text="Room" FontSize="8.5" HorizontalAlignment="Center" Margin="0,2,0,0"/></StackPanel>
                        </RadioButton>
                    </StackPanel>
                </Border>

                <!-- Floating library card -->
                <Border Style="{StaticResource FloatingCard}" HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="104,16,0,0" Width="224" MaxHeight="560" Padding="14,12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="THERMAL SENSORS" Style="{StaticResource SectionHeader}" Margin="2,0,0,6" />
                            <ListBox x:Name="SensorList" ItemsSource="{Binding SensorLibrary}"
                                     ItemTemplate="{StaticResource LibraryItemTemplate}"
                                     BorderThickness="0" Background="Transparent"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     PreviewMouseLeftButtonDown="Library_PreviewMouseLeftButtonDown"
                                     PreviewMouseMove="Library_PreviewMouseMove" />
                            <TextBlock Text="FURNITURE" Style="{StaticResource SectionHeader}" Margin="2,8,0,6" />
                            <ListBox x:Name="FurnitureList" ItemsSource="{Binding FurnitureLibrary}"
                                     ItemTemplate="{StaticResource LibraryItemTemplate}"
                                     BorderThickness="0" Background="Transparent"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     PreviewMouseLeftButtonDown="Library_PreviewMouseLeftButtonDown"
                                     PreviewMouseMove="Library_PreviewMouseMove" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Floating properties card -->
                <Border Style="{StaticResource FloatingCard}" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,16,16,0" Width="308" MaxHeight="720" Padding="18,16">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="PROPERTIES" Style="{StaticResource SectionHeader}" />
                            <ContentControl Content="{Binding SelectedProperties}"
                                            Visibility="{Binding SelectedProperties, Converter={StaticResource NullToVis}}" />

                            <StackPanel Visibility="{Binding SelectedProperties, Converter={StaticResource NullToVis}, ConverterParameter=invert}">
                                <Border Background="{StaticResource SidebarBrush}" CornerRadius="12" Padding="14" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="FLOOR" Style="{StaticResource SectionHeader}" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding ActiveFloorName, UpdateSourceTrigger=LostFocus}" />
                                        <TextBlock Text="Add a floor from a template:" Foreground="{StaticResource TextMutedBrush}"
                                                   FontSize="10.5" Margin="0,8,0,4" />
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Studio" Style="{StaticResource ToolbarButton}" Height="26" Padding="8,0" FontSize="11"
                                                    Command="{Binding AddTemplateFloorCommand}" CommandParameter="studio" />
                                            <Button Content="1-Bed" Style="{StaticResource ToolbarButton}" Height="26" Padding="8,0" FontSize="11"
                                                    Command="{Binding AddTemplateFloorCommand}" CommandParameter="onebed" />
                                            <Button Content="2-Bed" Style="{StaticResource ToolbarButton}" Height="26" Padding="8,0" FontSize="11"
                                                    Command="{Binding AddTemplateFloorCommand}" CommandParameter="twobed" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="10" Padding="12,8" Margin="0,0,0,10"
                                        Visibility="{Binding SelectionCount, Converter={StaticResource CountToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectionCount, StringFormat={}{0} items selected}"
                                                   FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="Drag to move together · Delete to remove · Ctrl+D to duplicate"
                                                   Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" TextWrapping="Wrap" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Nothing selected" Style="{StaticResource TitleText}" Margin="0,4,0,0" />
                                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0"
                                           Text="Pick the Select tool and click an element to edit it. Select a sensor to reveal its 32×24 thermal pixel grid and tune FOV, mount height and orientation." />
                                <Border Background="{StaticResource SidebarBrush}" CornerRadius="12" Padding="14" Margin="0,14,0,0">
                                    <StackPanel>
                                        <TextBlock Text="COVERAGE" Style="{StaticResource SectionHeader}" Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding CoveredPercent, StringFormat={}{0:0.#}% of floor covered}"
                                                   Foreground="{StaticResource TextBrush}" FontSize="22" FontWeight="Bold" />

                                        <ItemsControl ItemsSource="{Binding RoomCoverages}" Margin="0,10,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,4,0,0">
                                                        <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBrush}" FontSize="12" />
                                                        <TextBlock Grid.Column="1" Text="{Binding CoveredPercent, StringFormat={}{0:0}%}"
                                                                   Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                                                        <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Height="5" Margin="0,3,0,0"
                                                                     Minimum="0" Maximum="100" Value="{Binding CoveredPercent, Mode=OneWay}"
                                                                     Foreground="{StaticResource CoveredBrush}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" FontSize="11.5" Margin="0,10,0,0"
                                                   Text="Click Optimize Coverage to auto-place MLX90640 sensors for maximum coverage." />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Floating background-image controls (only when a plan image is loaded) -->
                <Border Style="{StaticResource FloatingCard}" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                        Margin="16,0,0,58" Width="230" Padding="14,12"
                        Visibility="{Binding HasBackground, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="FLOOR PLAN IMAGE" Style="{StaticResource SectionHeader}" Margin="0" />
                            <Button DockPanel.Dock="Right" Content="Remove" Style="{StaticResource ToolbarButton}" Height="22"
                                    Padding="6,0" FontSize="11" Command="{Binding RemoveBackgroundCommand}"
                                    Foreground="{StaticResource AccentBrush}" />
                        </DockPanel>
                        <TextBlock Text="Opacity" Style="{StaticResource FieldLabel}" />
                        <Slider Minimum="0.1" Maximum="1.0" Value="{Binding BackgroundOpacity}" />
                        <TextBlock Text="Scale (mm / pixel)" Style="{StaticResource FieldLabel}" />
                        <Slider Minimum="1" Maximum="60" Value="{Binding BackgroundScalePercent}" />
                        <CheckBox Content="Move background" IsChecked="{Binding MoveBackground}"
                                  Foreground="{StaticResource TextBrush}" Margin="0,8,0,0" />
                        <Button Content="✨  Detect rooms" Style="{StaticResource AccentButton}" Height="32" Margin="0,12,0,0"
                                Command="{Binding DetectRoomsCommand}"
                                ToolTip="Automatically create rooms from the floor-plan image" />
                        <TextBlock Text="Auto-creates rooms from the plan. Refine or add more with the Room tool."
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="10.5" TextWrapping="Wrap" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <!-- Floating status (bottom-left) -->
                <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                           Margin="20,0,0,26" MaxWidth="420" TextTrimming="CharacterEllipsis"
                           Foreground="{StaticResource TextMutedBrush}" FontSize="11.5" />


                <!-- Floating bottom toolbar -->
                <Border Style="{StaticResource FloatingCard}" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                        Margin="0,0,0,18" Padding="8,6">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="–" Style="{StaticResource RoundIconButton}" Command="{Binding ZoomOutCommand}" ToolTip="Zoom out" />
                        <TextBlock Text="{Binding Zoom, StringFormat={}{0:0} px/m}" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="11.5" Width="62" TextAlignment="Center" />
                        <Button Content="+" Style="{StaticResource RoundIconButton}" Command="{Binding ZoomInCommand}" ToolTip="Zoom in" />
                        <Button Content="⤢" Style="{StaticResource RoundIconButton}" Command="{Binding FitToViewCommand}" ToolTip="Fit to view" />
                        <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush2}" Margin="6,0" />
                        <Button Content="↶" Style="{StaticResource RoundIconButton}" Command="{Binding UndoCommand}" ToolTip="{Binding UndoLabel}" />
                        <Button Content="↷" Style="{StaticResource RoundIconButton}" Command="{Binding RedoCommand}" ToolTip="{Binding RedoLabel}" />
                        <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush2}" Margin="6,0" />
                        <Border Background="{StaticResource SidebarBrush}" CornerRadius="9" Padding="3" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="2D" GroupName="View" Style="{StaticResource SegRadio}"
                                             IsChecked="{Binding ViewMode, Converter={StaticResource EnumMatch}, ConverterParameter=TopDown2D}" />
                                <RadioButton Content="3D" GroupName="View" Style="{StaticResource SegRadio}"
                                             IsChecked="{Binding ViewMode, Converter={StaticResource EnumMatch}, ConverterParameter=Isometric}" />
                            </StackPanel>
                        </Border>
                        <ToggleButton IsChecked="{Binding LayoutLocked}" Width="36" Height="36" Margin="2,0" Cursor="Hand"
                                      ToolTip="Lock walls &amp; rooms so they can't be moved by accident (furniture &amp; sensors still move)">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Bd" CornerRadius="10" Background="Transparent">
                                        <TextBlock x:Name="Ico" Text="&#x1F513;" FontSize="15"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SidebarBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                            <Setter TargetName="Ico" Property="Text" Value="&#x1F512;" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush2}" Margin="6,0" />
                        <Button Style="{StaticResource AccentButton}" Height="34" Padding="14,0" Command="{Binding SaveCommand}" Content="Save" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
